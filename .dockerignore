# Keep the build context lean.

# VCS
.git
.gitignore
.gitattributes
.github

# Local virtualenvs / caches
.venv
venv
__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.coverage
.coverage.*
htmlcov
build
dist

# Runtime artefacts (never want host data inside the image)
data
output
config
test-db
*.log
*.sqlite
*.sqlite-*
*.db
*.db-*

# Secrets — never bake into an image
.env
.env.*
!.env.example

# Editor / OS
.vscode
.idea
.claude
.DS_Store
Thumbs.db
*.bak
*~

# Tooling that has no business inside the image
node_modules
*.swp
*.swo

